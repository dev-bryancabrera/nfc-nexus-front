# ─── API ──────────────────────────────────────────────
# URL de tu backend (Railway genera esto automáticamente si tienes el backend en el mismo proyecto)
VITE_API_URL=https://TU-BACKEND.up.railway.app/api

# ─── Supabase ─────────────────────────────────────────
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key

# ─── Dominio ──────────────────────────────────────────
# path      → nexusnfc.com/u/username
# subdomain → username.nexusnfc.com
VITE_DOMAIN_MODE=path
VITE_ROOT_DOMAIN=nexusnfc.com
VITE_PUBLIC_BASE_URL=https://TU-FRONTEND.up.railway.app
